def f(a, s, p):
    if a + s >= 65 and p == 3:
        return True
    if a + s >= 65 and p == 2:
        return True
    if a + s < 65 and p == 3:
        return False
    if p % 2 == 0:
        return f(a+1, s, p+1) or f(a*3, s, p+1) or f(a, s+1, p+1) or f(a, s*3, p+1)
    if p % 2 == 1:
        return f(a+1, s, p+1) or f(a*3, s, p+1) or f(a, s+1, p+1) or f(a, s*3, p+1)
for s in range(1,58):
    if f(6, s, 1) == True:
        print(s)
